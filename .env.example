# === Gemini auth ===
# Phase 12: Vertex AI preferred for production (higher quotas, ~$3-6/mo).
# Set USE_VERTEX_AI=true + GCP_PROJECT_ID + service-account JSON below.
USE_VERTEX_AI=true
GEMINI_API_KEY=your-gemini-api-key-here
# Option B (Vertex AI): leave GEMINI_API_KEY blank and set the GCP values below
# plus a service account JSON. Not needed if you use the AI Studio key above.

# === GCP / Vertex AI (optional) ===
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./secrets/gcp-service-account.json
GEMINI_MODEL_QUALIFIER=gemini-2.5-flash-lite
GEMINI_MODEL_RSS_PARSER=gemini-2.5-flash-lite
GEMINI_MODEL_PERSONALIZER=gemini-2.5-flash
GEMINI_MODEL_WRITER=gemini-2.5-pro
GEMINI_MODEL_STRATEGIST=gemini-2.5-pro
GEMINI_MODEL_VALIDATOR=gemini-2.5-flash-lite
GEMINI_MODEL_FALLBACK=gemini-2.5-flash

# === Primary Data Sources ===
VIBE_PROSPECTING_API_KEY=your-vibe-prospecting-key
HUNTER_API_KEY=your-hunter-api-key
SCRAPEGRAPH_API_KEY=your-scrapegraph-key
APIFY_TOKEN_1=your-apify-token-1
APIFY_TOKEN_2=your-apify-token-2
APIFY_TOKEN_3=your-apify-token-3
APIFY_TOKEN_4=your-apify-token-4
SERPAPI_KEY=your-serpapi-key
NEWSDATA_API_KEY=your-newsdata-key
COMPANIES_API_TOKEN=your-companies-api-token

# === Phase 11 — Apify discovery actors (optional overrides) ===
# Disabled by default until you verify working actor slugs on apify.com/store.
# Pick free or pay-per-result actors, paste their slugs, then flip to true.
CRUNCHBASE_APIFY_ACTOR=
WELLFOUND_APIFY_ACTOR=
ENABLE_CRUNCHBASE_DISCOVERY=false
ENABLE_WELLFOUND_DISCOVERY=false

# === Parked (not wired in Phase 1) ===
ABSTRACT_EMAIL_API_KEY=your-abstract-email-key
ROCKETREACH_API_KEY=your-rocketreach-key
PHANTOMBUSTER_API_KEY=your-phantombuster-key
CLAY_API_KEY=your-clay-key
OPENALEX_POLITE_EMAIL=your-email@example.com

# === Outputs (wired in Phase 7) ===
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
TELEGRAM_SEND_EMPTY_DIGEST=true
GOOGLE_SHEETS_CREDS_PATH=./secrets/gcp-service-account.json
SHEET_ID=your-google-sheet-id
SHEET_TAB_TUTRAIN=TUTRAIN_Leads
SHEET_TAB_CONTENT=eQOURSE_Content_Leads
SHEET_TAB_AI_DATA=eQOURSE_AI_Data_Leads

# === App config ===
LOG_LEVEL=INFO
DAILY_LEAD_TARGET_PER_SEGMENT=15
SQLITE_PATH=./data/leads.db
STREAMLIT_PASSWORD=
